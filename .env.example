AUTH_DB_PATH=data/auth.db

# Atlassian Cloud OAuth 2.0 (3LO)
# Register this exact callback URL in the Atlassian Developer Console.
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:8501/?atlassian_callback=1
# Optional. If omitted, a local key is generated in data/.oauth_token_key.
PROJECT_BRAIN_TOKEN_ENCRYPTION_KEY=

# SMTP notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=notifications@example.com
SMTP_PASSWORD=replace-me
SMTP_FROM=notifications@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
