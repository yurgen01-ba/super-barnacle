[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "replace-with-a-long-random-secret"

[auth.google]
client_id = "google-client-id"
client_secret = "google-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# Streamlit accepts OIDC providers, not generic OAuth providers. Configure an
# OIDC broker/identity provider connected to Facebook Login and put its
# discovery endpoint and client credentials here.
[auth.facebook]
client_id = "facebook-oidc-client-id"
client_secret = "facebook-oidc-client-secret"
server_metadata_url = "https://your-oidc-broker.example/.well-known/openid-configuration"
