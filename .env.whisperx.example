WHISPERX_HOTWORDS=Jira, Jira task, title, in scope of this task, info panel, summary, accounts, OrgMeter, Confluence, white label, field scope
WHISPERX_VAD_ONSET=0.35
WHISPERX_VAD_OFFSET=0.25
WHISPERX_ENABLE_ALIGNMENT=true
WHISPERX_ENABLE_DIARIZATION=true
